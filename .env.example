# Copy this to .env and fill in your values
# Never commit .env to git

# Your public media base URL (domain only; no trailing slash)
# Example: https://media.stokeleads.com
R2_BASE_URL=https://media.stokeleads.com

# The folder inside your R2 bucket for this specific site
# e.g. "colville-plumbing" maps to r2://bucket/colville-plumbing/
R2_SITE_FOLDER=roofing

# Your deployed site URL (used for sitemap & SEO)
SITE_URL=https://roofing.stokeleads.com
PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here