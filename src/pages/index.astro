---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import AboutSection from '../components/AboutSection.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import ContactSection from '../components/ContactSection.astro';
import MapSection from '../components/MapSection.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FAQSection from '../components/FAQSection.astro';
import Footer from '../components/Footer.astro';
import SplitFeature from '../components/SplitFeature.astro';
import RecentWork from '../components/RecentWork.astro';

const serviceProcessSteps = [
  { title: 'Call or Submit Request', description: 'Share your location, system type, and issue details with our team.' },
  { title: 'Diagnostic Visit', description: 'We inspect equipment, identify root causes, and provide practical recommendations.' },
  { title: 'Repair or Service Execution', description: 'Approved work is completed with a focus on uptime, safety, and consistency.' },
  { title: 'Performance Follow-Up', description: 'We review outcomes and recommend maintenance intervals to reduce repeat failures.' },
];

const transformationGalleryProjects = [
  { title: 'Rooftop HVAC Unit Service', category: 'Commercial HVAC', image: 'https://media.stokeleads.com/r3-services/R3-12.avif' },
  { title: 'Split-System Diagnostics', category: 'Commercial HVAC', image: 'https://media.stokeleads.com/r3-services/R3-19.avif' },
  { title: 'Walk-In Refrigeration Support', category: 'Refrigeration', image: 'https://media.stokeleads.com/r3-services/R3-15.avif' },
  { title: 'Prep Rail Temperature Recovery', category: 'Refrigeration', image: 'https://media.stokeleads.com/r3-services/R3-22.avif' },
  { title: 'Conveyor Oven Service', category: 'Kitchen Equipment', image: 'https://media.stokeleads.com/r3-services/R3-8.avif' },
  { title: 'Ignition Component Replacement', category: 'Kitchen Equipment', image: 'https://media.stokeleads.com/r3-services/R3-26.avif' },
  { title: 'Motor and Airflow Repairs', category: 'Ventilation', image: 'https://media.stokeleads.com/r3-services/R3-27.avif' },
  { title: 'Electrical Load Diagnostics', category: 'Diagnostics', image: 'https://media.stokeleads.com/r3-services/R3-23.avif' },
  { title: 'Deep Coil Cleaning Program', category: 'Preventive Maintenance', image: 'https://media.stokeleads.com/r3-services/R3-2.avif' },
  { title: 'Filter Replacement Service', category: 'Preventive Maintenance', image: 'https://media.stokeleads.com/r3-services/R3-30.avif' },
  { title: 'Component Reliability Checks', category: 'Preventive Maintenance', image: 'https://media.stokeleads.com/r3-services/R3-31.avif' },
  { title: 'Scheduled PM Execution', category: 'Preventive Maintenance', image: 'https://media.stokeleads.com/r3-services/R3-32.avif' },
];

---

<BaseLayout>
  <Header />
  <main>
    <Hero />
    <ServicesGrid />
    <section class="section">
      <div class="container">
        <SplitFeature
          eyebrow="Fast Service Triage"
          title="Commercial Service Requests Reviewed in Under 24 Hours"
          description="Share your system issue and facility details. Our team responds with clear next steps built around operational urgency."
          image="https://media.stokeleads.com/r3-services/truck.avif"
          buttonText="Request Service Support"
          buttonHref="#contact"
        />
      </div>
    </section>
    <section class="section">
      <div class="container">
        <ProcessSteps
          steps={serviceProcessSteps}
          title="Our Commercial Service Process"
          subtitle="A practical four-step workflow designed to restore uptime and keep critical systems reliable."
        />
      </div>
    </section>
    <AboutSection />
    <section class="section">
      <div class="container">
        <RecentWork projects={transformationGalleryProjects} />
      </div>
    </section>
    <ReviewsSection />
    <FAQSection />
    <ContactSection />
    <MapSection />
  </main>
  <Footer />
</BaseLayout>
