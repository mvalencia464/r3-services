---
// src/pages/thanks.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../config/site';
---

<BaseLayout title={`Thank You | ${SITE.name}`} description="We received your message and will be in touch soon.">
  <Header />
  <main class="thanks">
    <div class="container thanks__content">
      <span class="thanks__icon" aria-hidden="true"></span>
      <h1>Message Received!</h1>
      <p>Thanks for reaching out to <strong>{SITE.name}</strong>. We'll give you a call back shortly.</p>
      <p>Need to talk now? Call us directly:</p>
      <a href={`tel:${SITE.phone.replace(/\D/g,'')}`} class="btn btn--primary">
        Call {SITE.phone}
      </a>
      <a href="/" class="back-link">Back to homepage</a>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .thanks {
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .thanks__content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .thanks__icon {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    display: inline-block;
    position: relative;
    background: rgba(91, 196, 232, 0.08);
  }

  .thanks__icon::before,
  .thanks__icon::after {
    content: "";
    position: absolute;
    background: var(--accent2);
    border-radius: 999px;
  }

  .thanks__icon::before {
    width: 0.52rem;
    height: 0.13rem;
    left: 1.2rem;
    top: 2.15rem;
    transform: rotate(42deg);
  }

  .thanks__icon::after {
    width: 1.45rem;
    height: 0.13rem;
    left: 1.55rem;
    top: 1.95rem;
    transform: rotate(-43deg);
  }

  .thanks__content h1 { color: var(--text); }
  .thanks__content p  { color: var(--muted); font-size: 1.05rem; }

  .back-link {
    color: var(--muted);
    font-size: 0.9rem;
    margin-top: 0.5rem;
    text-decoration: none;
  }

  .back-link:hover { color: var(--accent2); }
</style>
