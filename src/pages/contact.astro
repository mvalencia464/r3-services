---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import TeamGrid from '../components/TeamGrid.astro';
import MapSection from '../components/MapSection.astro';
import { SITE } from '../config/site';

const teamMembers = [
  { name: 'Miguel Alvarez', role: 'Owner / Licensed Contractor', image: 'https://media.stokeleads.com/roofing/miguel.avif' },
  { name: 'Khilo Ramirez', role: 'Customer Care Lead', image: 'https://media.stokeleads.com/roofing/khilo.avif' },
  { name: 'Joel Jacobsen', role: 'Project Manager', image: 'https://media.stokeleads.com/roofing/SCR-20260428-mkqy.avif' },
  { name: 'Daniel Ortega', role: 'Lead Installer', image: 'https://media.stokeleads.com/roofing/SCR-20260428-mksa.avif' },
  { name: 'Mariana Soto', role: 'Site Supervisor', image: 'https://media.stokeleads.com/roofing/SCR-20260428-mksx.avif' },
  { name: 'Hank Richardson', role: 'Production Coordinator', image: 'https://media.stokeleads.com/roofing/SCR-20260428-mkun.avif' },
];
---

<BaseLayout
  title={`Contact ${SITE.name} | Free Roof Estimate`}
  description={`Contact ${SITE.name} for a free roof estimate, emergency leak response, and full roofing support across Florida.`}
>
  <Header />

  <main>
    <section class="section contact-hero">
      <div class="container">
        <span class="section-label">Standalone Contact Page</span>
        <h1>Talk to a Roofing Specialist Today</h1>
        <p>
          Call now for urgent issues or submit a free estimate request. Our local team
          follows up quickly with clear next steps.
        </p>
        <div class="contact-hero__actions">
          <a href={`tel:${SITE.phone.replace(/\D/g, '')}`} class="btn btn--primary">Call {SITE.phone}</a>
          <a href={`mailto:${SITE.email}`} class="btn btn--outline">Email {SITE.email}</a>
        </div>
      </div>
    </section>

    <ContactSection />

    <section class="section section--alt">
      <div class="container">
        <TeamGrid members={teamMembers} title="Meet the Team Behind Your Project" />
      </div>
    </section>

    <MapSection />
  </main>

  <Footer />
</BaseLayout>

<style>
  .contact-hero {
    padding-top: 8rem;
  }

  .contact-hero h1 {
    color: var(--text);
    margin-bottom: 0.7rem;
  }

  .contact-hero p {
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.7;
    max-width: 68ch;
  }

  .contact-hero__actions {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
</style>
