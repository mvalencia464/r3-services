---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import TeamGrid from '../components/TeamGrid.astro';
import MapSection from '../components/MapSection.astro';
import { SITE } from '../config/site';

const teamMembers = [
  { name: 'Nathaniel Roddy', role: 'Owner / Service Lead', image: 'https://media.stokeleads.com/r3-services/R3-23.avif' },
  { name: 'Field Diagnostics Team', role: 'HVAC & Refrigeration Support', image: 'https://media.stokeleads.com/r3-services/R3-24.avif' },
  { name: 'Equipment Service Team', role: 'Hot-Side & Cold-Side Repair', image: 'https://media.stokeleads.com/r3-services/R3-8.avif' },
  { name: 'Preventive Maintenance Team', role: 'Inspection & Performance Programs', image: 'https://media.stokeleads.com/r3-services/R3-30.avif' },
];
---

<BaseLayout
  title={`Contact ${SITE.name} | Commercial Service Request`}
  description={`Contact ${SITE.name} for commercial HVAC, refrigeration, and kitchen equipment service support.`}
>
  <Header />

  <main>
    <section class="section contact-hero">
      <div class="container">
        <span class="section-label">Standalone Contact Page</span>
        <h1>Talk to a Commercial Service Specialist Today</h1>
        <p>
          Call now for urgent system issues or submit a service request. Our local team
          follows up quickly with clear next steps.
        </p>
        <div class="contact-hero__actions">
          <a href={`tel:${SITE.phone.replace(/\D/g, '')}`} class="btn btn--primary">Call {SITE.phone}</a>
          <a href={`mailto:${SITE.email}`} class="btn btn--outline">Email {SITE.email}</a>
        </div>
      </div>
    </section>

    <ContactSection />

    <section class="section section--alt">
      <div class="container">
        <TeamGrid members={teamMembers} title="Meet the Team Behind Your Service Program" />
      </div>
    </section>

    <MapSection />
  </main>

  <Footer />
</BaseLayout>

<style>
  .contact-hero {
    padding-top: 8rem;
  }

  .contact-hero h1 {
    color: var(--text);
    margin-bottom: 0.7rem;
  }

  .contact-hero p {
    color: var(--muted);
    font-size: 1.03rem;
    line-height: 1.7;
    max-width: 68ch;
  }

  .contact-hero__actions {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
</style>
