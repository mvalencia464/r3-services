---
// src/pages/services/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProcessSteps from '../../components/ProcessSteps.astro';
import TestimonialGrid from '../../components/TestimonialGrid.astro';
import RecentWork from '../../components/RecentWork.astro';
import { SITE } from '../../config/site';
import { r2img } from '../../lib/r2';

export function getStaticPaths() {
  return SITE.services.map(service => ({
    params: { slug: service.slug },
    props:  { service },
  }));
}

const { service } = Astro.props;

// Related services (exclude current)
const related = SITE.services.filter(s => s.slug !== service.slug).slice(0, 3);
const pageSteps = [
  { title: 'Diagnostic Assessment', description: `We inspect system conditions tied to ${service.title.toLowerCase()} and identify root causes.` },
  { title: 'Clear Service Plan', description: 'You receive a practical scope, timeline, and prioritized next steps.' },
  { title: 'Repair or Maintenance Execution', description: 'Our technicians complete approved work with safety and uptime in mind.' },
  { title: 'Performance Review', description: 'We confirm operation and share maintenance guidance to reduce repeat failures.' },
];
const pageTestimonials = SITE.reviews.slice(0, 3).map((item) => ({
  name: item.name,
  city: item.city,
  text: item.text,
  rating: item.stars,
}));
const showcaseProjects = [
  { title: 'RTU Service and Stabilization', category: 'Commercial HVAC', image: 'https://media.stokeleads.com/r3-services/R3-12.avif' },
  { title: 'Walk-In Temperature Recovery', category: 'Refrigeration', image: 'https://media.stokeleads.com/r3-services/R3-28.avif' },
  { title: 'Kitchen Equipment Diagnostics', category: 'Equipment Repair', image: 'https://media.stokeleads.com/r3-services/R3-21.avif' },
];
const serviceFaqs = [
  {
    q: `How quickly can you schedule ${service.title.toLowerCase()} service?`,
    a: `Most projects start with a fast inspection window. Emergency cases are prioritized, and planned work is scheduled based on material availability and permits.`,
  },
  {
    q: "Do you service active commercial environments?",
    a: "Yes. We regularly support restaurants and other operating facilities where minimizing downtime is critical.",
  },
  {
    q: "Can this service be included in preventive maintenance?",
    a: "Absolutely. We can align this service with a maintenance interval to improve reliability and catch failures earlier.",
  },
];
---

<BaseLayout
  title={`${service.title} | ${SITE.name} — ${SITE.city}, ${SITE.state}`}
  description={service.shortDesc}
>
  <Header />

  <main>
    <!-- Page Hero -->
    <section class="service-hero" style={`background-image: url('${r2img(service.image)}')`}>
      <div class="service-hero__overlay"></div>
      <div class="container service-hero__content">
        <a href="/#services" class="breadcrumb">All Services</a>
        <h1>{service.title}</h1>
        <p>{service.shortDesc}</p>
      </div>
    </section>

    <!-- Service Detail -->
    <section class="section">
      <div class="container service-detail">

        <div class="service-detail__main">
          <h2>About This Service</h2>
          <p class="service-detail__body">{service.fullDesc}</p>

          <h3>What's Included</h3>
          <ul class="highlights">
            {service.highlights.map(h => (
              <li>{h}</li>
            ))}
          </ul>

          <div class="service-detail__panel-grid">
            <article class="detail-panel">
              <h4>Why Commercial Facilities Need This Service</h4>
              <p>
                Heavy runtime cycles and fast-paced operations can accelerate component wear when issues go unchecked.
                This service is designed to protect uptime, performance, and day-to-day operational consistency.
              </p>
            </article>
            <article class="detail-panel">
              <h4>Our Typical Process</h4>
              <ol>
                <li>Detailed on-site system assessment</li>
                <li>Clear scope with practical recommendations</li>
                <li>Repair or maintenance execution</li>
                <li>Final performance confirmation checklist</li>
              </ol>
            </article>
          </div>

          <h3>Frequently Asked Questions</h3>
          <div class="faq-list">
            {serviceFaqs.map((faq) => (
              <details class="faq-item">
                <summary>{faq.q}</summary>
                <p>{faq.a}</p>
              </details>
            ))}
          </div>

          <div class="service-detail__cta">
            <a href={`tel:${SITE.phone.replace(/\D/g,'')}`} class="btn btn--primary">
              Call {SITE.phone}
            </a>
            <a href="/#contact" class="btn btn--dark">
              Request Service
            </a>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="service-sidebar">
          <div class="sidebar-card">
            <h4>Request Priority Support</h4>
            <p>Call or message us anytime for urgent commercial system issues.</p>
            <a href={`tel:${SITE.phone.replace(/\D/g,'')}`} class="btn btn--primary" style="width:100%; justify-content:center; margin-top:1rem;">
              Call {SITE.phone}
            </a>
            <a href={`mailto:${SITE.email}`} class="sidebar-email">{SITE.email}</a>
          </div>

          <div class="sidebar-card sidebar-card--areas">
            <h4>Service Areas</h4>
            <ul>
              {SITE.serviceAreas.map(area => <li>{area}</li>)}
            </ul>
          </div>
        </aside>

      </div>
    </section>

    <!-- Related Services -->
    {related.length > 0 && (
      <section class="section section--alt">
        <div class="container">
          <h2 style="color: var(--text); margin-bottom: 1.5rem;">Other Services</h2>
          <div class="related-grid">
            {related.map(s => (
              <a href={`/services/${s.slug}`} class="related-card">
                <div>
                  <strong>{s.title}</strong>
                  <p>{s.shortDesc}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="section">
      <div class="container">
        <ProcessSteps
          steps={pageSteps}
          title="How This Project Works"
          subtitle="From first diagnostics to final confirmation, we keep your service request clear and organized."
        />
      </div>
    </section>

    <section class="section">
      <div class="container">
        <RecentWork projects={showcaseProjects} title="Related Commercial Projects" />
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <TestimonialGrid testimonials={pageTestimonials} title="Social Proof from Nearby Operators" />
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .service-hero {
    position: relative;
    min-height: 40vh;
    display: flex;
    align-items: flex-end;
    background-size: cover;
    background-position: center;
    background-color: var(--deep);
  }

  .service-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(6,13,20,0.94) 0%, rgba(6,13,20,0.52) 100%);
  }

  .service-hero__content {
    position: relative;
    z-index: 1;
    padding-bottom: 3rem;
    padding-top: 2rem;
  }

  .breadcrumb {
    display: inline-block;
    color: var(--accent2);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
    text-decoration: none;
  }

  .service-hero__content h1 {
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .service-hero__content p {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 55ch;
  }

  /* Detail layout */
  .service-detail {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .service-detail { grid-template-columns: 1fr; }
  }

  .service-detail__main h2 {
    color: var(--text);
    margin-bottom: 1rem;
  }

  .service-detail__main h3 {
    color: var(--text);
    margin: 2rem 0 0.75rem;
    font-size: 1.3rem;
  }

  .service-detail__body {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .highlights li {
    color: var(--text);
    font-size: 1rem;
    padding: 0.6rem 0 0.6rem 1.15rem;
    border-bottom: 1px solid var(--border);
    position: relative;
  }

  .highlights li::before {
    content: "";
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--accent2);
    opacity: 0.8;
    position: absolute;
    left: 0;
    top: 1rem;
  }

  .service-detail__cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .service-detail__panel-grid {
    margin-top: 1.1rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 700px) {
    .service-detail__panel-grid {
      grid-template-columns: 1fr;
    }
  }

  .detail-panel {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem;
  }

  .detail-panel h4 {
    color: var(--text);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.15rem;
    margin-bottom: 0.35rem;
  }

  .detail-panel p {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .detail-panel ol {
    margin-left: 1.1rem;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.75;
  }

  .faq-list {
    margin-top: 0.5rem;
    display: grid;
    gap: 0.6rem;
  }

  .faq-item {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.8rem 0.95rem;
    background: rgba(255, 255, 255, 0.01);
  }

  .faq-item summary {
    cursor: pointer;
    color: var(--text);
    font-size: 0.93rem;
    font-weight: 700;
  }

  .faq-item p {
    margin-top: 0.55rem;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  /* Sidebar */
  .service-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: sticky;
    top: 80px;
  }

  .sidebar-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    box-shadow: 0 16px 32px rgba(0,0,0,0.25);
  }

  .sidebar-card h4 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .sidebar-card p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .sidebar-email {
    display: block;
    text-align: center;
    color: var(--muted);
    font-size: 0.85rem;
    margin-top: 0.75rem;
  }

  .sidebar-card--areas ul {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .sidebar-card--areas li {
    font-size: 0.85rem;
    color: var(--muted);
    padding-left: 0.85rem;
    position: relative;
  }

  .sidebar-card--areas li::before {
    content: "";
    width: 0.35rem;
    height: 0.35rem;
    border-radius: 50%;
    background: var(--accent2);
    position: absolute;
    left: 0;
    top: 0.45rem;
  }

  /* Related */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .related-card {
    display: block;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, transform 0.2s;
  }

  .related-card:hover {
    border-color: var(--accent2);
    transform: translateY(-2px);
  }

  .related-card strong {
    display: block;
    color: var(--text);
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .related-card p {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
  }

</style>
