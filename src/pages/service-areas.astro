---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';
import MapSection from '../components/MapSection.astro';
import { SITE } from '../config/site';
---

<BaseLayout
  title={`Service Areas | ${SITE.name}`}
  description={`Commercial HVAC, refrigeration, and kitchen equipment service areas for ${SITE.name}.`}
>
  <Header />

  <main>
    <section class="section service-areas-hero">
      <div class="container">
        <span class="section-label">Coverage</span>
        <h1>Commercial Service Areas Across the Region</h1>
        <p>
          We focus on high-demand markets where restaurants and commercial teams need reliable HVAC,
          refrigeration, and equipment support.
        </p>
      </div>
    </section>

    <section class="section section--alt">
      <div class="container">
        <div class="areas-grid">
          {SITE.serviceAreaRegions.map((region) => (
            <article class="area-card">
              <h2>{region.title}</h2>
              <p>{region.blurb}</p>
              <ul>
                {region.locations.map((location) => <li>{location}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <MapSection />
    <CTABanner />
  </main>

  <Footer />
</BaseLayout>

<style>
  .service-areas-hero h1 {
    color: var(--text);
    margin-bottom: 0.8rem;
  }

  .service-areas-hero p {
    color: var(--muted);
    max-width: 64ch;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .areas-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .area-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.2rem;
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.25);
  }

  .area-card h2 {
    color: var(--text);
    font-size: 1.4rem;
    margin-bottom: 0.45rem;
  }

  .area-card p {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 0.8rem;
  }

  .area-card ul {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.35rem 0.7rem;
  }

  .area-card li {
    color: var(--text);
    font-size: 0.84rem;
    position: relative;
    padding-left: 0.75rem;
  }

  .area-card li::before {
    content: "";
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 50%;
    background: var(--accent2);
    position: absolute;
    left: 0;
    top: 0.45rem;
  }
</style>
