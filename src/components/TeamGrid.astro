---
import { r2img } from '../lib/r2';

interface Member {
  name: string;
  role: string;
  image: string;
}

interface Props {
  members: Member[];
  title?: string;
}

const { members, title = "Meet Your Service Experts" } = Astro.props;
---

<section class="team-section">
  <div class="section-header">
    <span class="section-label">Our People</span>
    <h2>{title}</h2>
  </div>

  <div class="team-grid">
    {members.map(member => (
      <div class="team-card panel-card u-hover-lift">
        <div class="team-image">
          <img src={r2img(member.image)} alt={member.name} loading="lazy" />
        </div>
        <div class="team-content">
          <h3>{member.name}</h3>
          <p>{member.role}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .team-section {
    width: 100%;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .team-card {
    overflow: hidden;
  }

  .team-image {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .team-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.4);
    transition: filter 0.3s ease;
  }

  .team-card:hover .team-image img {
    filter: grayscale(0);
  }

  .team-content {
    padding: 1.5rem;
    text-align: center;
  }

  .team-content h3 {
    font-size: 1.5rem;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .team-content p {
    color: var(--accent2);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }
</style>
