---
// src/components/ServicesGrid.astro
import { SITE } from '../config/site';
import { r2img } from '../lib/r2';
---

<section id="services" class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">What We Do</span>
      <h2>Roofing Services Across Florida</h2>
      <p>From emergency leak repairs to full roof installation, we deliver reliable roofing solutions built for Florida weather.</p>
    </div>

    <div class="services-grid">
      {SITE.services.map((service) => (
        <a href={`/services/${service.slug}`} class="service-card">
          <div class="service-card__img-wrap">
            <img
              src={r2img(service.image)}
              alt={service.title}
              loading="lazy"
              width="400"
              height="260"
            />
          </div>
          <div class="service-card__body">
            <h3>{service.title}</h3>
            <p>{service.shortDesc}</p>
            <span class="service-card__cta">Learn More →</span>
          </div>
        </a>
      ))}
    </div>

    <div class="services-cta">
      <p>Need a custom roofing scope? We handle residential projects of every size statewide.</p>
      <a href={`tel:${SITE.phone.replace(/\D/g,'')}`} class="btn btn--dark">
        Call {SITE.phone}
      </a>
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    background: var(--panel);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 14px 28px rgba(0,0,0,0.24);
    border: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s cubic-bezier(.16,1,.3,1), box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: rgba(91, 196, 232, 0.42);
    box-shadow: 0 24px 40px rgba(0,0,0,0.34);
  }

  .service-card__img-wrap {
    position: relative;
    aspect-ratio: 400 / 260;
    overflow: hidden;
    background: var(--surface);
  }

  .service-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .service-card:hover .service-card__img-wrap img {
    transform: scale(1.05);
  }

  .service-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .service-card__body h3 {
    color: var(--text);
    font-size: 1.3rem;
  }

  .service-card__body p {
    color: var(--muted);
    font-size: 0.95rem;
    flex: 1;
  }

  .service-card__cta {
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-top: 0.5rem;
  }

  .services-cta {
    text-align: center;
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .services-cta p {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: none;
  }
</style>
