---
// src/components/Footer.astro
import { SITE } from '../config/site';
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <img
        class="footer__logo"
        src="https://media.stokeleads.com/r3-services/logo.avif"
        alt={SITE.name}
        loading="lazy"
        width="420"
        height="140"
      />
      <p class="footer__tagline">{SITE.tagline}</p>
      <p class="footer__copy">{SITE.footerText}</p>
    </div>

    <div class="footer__contact-group" aria-label="Contact information">
      <p class="footer__heading">Contact</p>
      <div class="footer__contact" aria-label="Contact information">
        <a class="footer__contact-link" href={`tel:${SITE.phone.replace(/\D/g, '')}`}>{SITE.phone}</a>
        <a class="footer__contact-link" href={`mailto:${SITE.email}`}>{SITE.email}</a>
        <p class="footer__address">{SITE.address}</p>
      </div>
    </div>

    <div class="footer__links-group">
      <p class="footer__heading">Explore</p>
      <nav class="footer__nav" aria-label="Footer navigation">
        {SITE.navLinks.map(link => (
          <a href={link.href} class="footer__link">{link.label}</a>
        ))}
        <a href="/library" class="footer__link">Resources</a>
        <a href="/hiring" class="footer__link">Careers</a>
        <a href="/terms" class="footer__link">Terms</a>
        <a href="/policy" class="footer__link">Privacy</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(160deg, #151519 0%, #101014 55%, #1a1a20 100%);
    padding: 2rem 0 4rem; /* bottom padding for mobile sticky CTA */
    border-top: 1px solid var(--border);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .footer__logo {
    width: clamp(86px, 8vw, 110px);
    height: auto;
    display: block;
    margin-bottom: 0.35rem;
  }

  .footer__copy {
    font-size: 0.8rem;
    color: var(--muted);
    max-width: none;
    margin-bottom: 0;
    line-height: 1.55;
  }

  .footer__tagline {
    color: var(--text);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer__contact-group {
    display: flex;
    flex-direction: column;
  }

  .footer__heading {
    color: var(--text);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.45rem;
  }

  .footer__contact-link,
  .footer__address {
    color: var(--muted);
    font-size: 0.83rem;
    text-decoration: none;
    line-height: 1.5;
  }

  .footer__contact-link:hover {
    color: var(--accent2);
  }

  .footer__links-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.9rem;
  }

  .footer__nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.55rem 1rem;
  }

  .footer__link {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 500;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: color 0.15s;
  }

  .footer__link:hover { color: var(--accent2); }

  @media (max-width: 960px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer__logo {
      margin-left: auto;
      margin-right: auto;
    }

    .footer__contact-group,
    .footer__contact,
    .footer__links-group {
      align-items: center;
    }

    .footer__nav {
      grid-template-columns: 1fr;
      justify-items: center;
    }
  }
</style>
