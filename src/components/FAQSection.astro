---
import { SITE } from '../config/site';

const faqs = [
  {
    question: "What types of facilities do you service?",
    answer:
      "We primarily support restaurants, foodservice operations, and light commercial buildings that rely on HVAC, refrigeration, and kitchen equipment uptime.",
  },
  {
    question: "How fast can you respond to an urgent system failure?",
    answer:
      "Urgent calls are prioritized. We dispatch quickly to stabilize critical issues and then provide a clear repair path to restore dependable operation.",
  },
  {
    question: "Do you only work on HVAC systems?",
    answer:
      "No. R3 Services supports commercial HVAC, refrigeration, and both hot-side and cold-side kitchen equipment.",
  },
  {
    question: "Do you offer preventive maintenance programs?",
    answer:
      "Yes. We create tailored maintenance plans with cleaning, inspections, and performance checks to reduce downtime and catch failures early.",
  },
  {
    question: "Can you service walk-ins and prep refrigeration?",
    answer:
      `Yes. We service walk-in coolers/freezers, reach-ins, prep rails, and related controls throughout ${SITE.serviceAreas.slice(0, 4).join(", ")} and nearby markets.`,
  },
  {
    question: "Will I receive clear recommendations before work starts?",
    answer:
      "Absolutely. Every visit includes practical findings, prioritized recommendations, and straightforward communication on next steps.",
  },
];
---

<section class="section section--alt">
  <div class="container">
    <div class="section-header">
      <span class="section-label">FAQ</span>
      <h2>Commercial Service Questions, Answered</h2>
      <p>Clear guidance on service scope, response expectations, and preventive maintenance support.</p>
    </div>

    <div class="faq-list">
      {faqs.map((faq) => (
        <details class="faq-item">
          <summary>{faq.question}</summary>
          <p>{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list {
    display: grid;
    gap: 0.75rem;
  }

  .faq-item {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--panel);
    padding: 0.95rem 1.1rem;
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
  }

  .faq-item summary {
    cursor: pointer;
    color: var(--text);
    font-weight: 700;
    font-size: 0.95rem;
  }

  .faq-item p {
    margin-top: 0.65rem;
    color: var(--muted);
    font-size: 0.93rem;
    line-height: 1.65;
  }
</style>
